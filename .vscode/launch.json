{
  "version": "0.2.0",
  "configurations": [
    // ── Application ───────────────────────────────────────────────────────────
    {
      "name": "Debug: ClickinDashboard",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/macos-debug/src/ClickinDashboard.app/Contents/MacOS/ClickinDashboard",
      "args": [],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "CMake: Build (macOS Debug)",
      "stopOnEntry": false
    },

    // ── Tests ─────────────────────────────────────────────────────────────────
    {
      "name": "Debug: Core Tests",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/macos-debug/tests/core/test_core",
      "args": ["--gtest_filter=*"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "CMake: Build (macOS Debug)",
      "stopOnEntry": false
    },
    {
      "name": "Debug: Provider Tests",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/macos-debug/tests/providers/test_providers",
      "args": ["--gtest_filter=*"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "CMake: Build (macOS Debug)",
      "stopOnEntry": false
    }
  ]
}
